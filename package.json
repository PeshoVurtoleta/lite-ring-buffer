  "main": "./RingBuffer.js",
  "module": "./RingBuffer.js",
  "types": "./RingBuffer.d.ts",
  "exports": {
    ".": {
      "types": "./RingBuffer.d.ts",
      "node": "./RingBuffer.js",
      "import": "./RingBuffer.js",
      "default": "./RingBuffer.js"
    }
  },
  "files": [
    "RingBuffer.js",
    "RingBuffer.d.ts",
    "README.md",
    "llms.txt",
    "LICENSE.txt"
  ],
  "scripts": {
    "test": "vitest run"
  },
  "keywords": [
    "ring-buffer",
    "circular-buffer",
    "float32",
    "zero-gc",
    "telemetry",
    "sliding-window",
    "lite",
    "no-allocation",
    "performance"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
